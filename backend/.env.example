# Copy to .env and adjust (optional — defaults work for local SQLite dev)

DATABASE_URL=sqlite:///./finance.db
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Optional Redis EOD quote cache
# REDIS_URL=redis://localhost:6379/0
EOD_CACHE_HOURS=24
PRICE_CACHE_TTL=120

# Logging
LOG_LEVEL=INFO
# LOG_HEALTH=true
# LOG_SQL=true

PORT=8000

# Plaid API (for bank linking and transactions)
# Get these from https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here

# sandbox | development | production
PLAID_ENV=sandbox

# Comma-separated products, e.g. transactions,auth,identity
PLAID_PRODUCTS=transactions

# Comma-separated country codes
PLAID_COUNTRY_CODES=US