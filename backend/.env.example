# Copy to .env and adjust (optional — defaults work for local SQLite dev)

DATABASE_URL=sqlite:///./finance.db
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Optional Redis EOD quote cache
# REDIS_URL=redis://localhost:6379/0
EOD_CACHE_HOURS=24
PRICE_CACHE_TTL=120

# Logging
LOG_LEVEL=INFO
# LOG_HEALTH=true
# LOG_SQL=true

PORT=8000

# Optional API key — when set, all /api routes except GET /api/health require
# X-API-Key or Authorization: Bearer <key>. Leave unset for local dev.
# API_KEY=your-secret-key
# FINANCE_API_KEY=your-secret-key

# Plaid — NOT wired in app.py (no routes/SDK). Safe to omit for local dev.
# CSV bank import only today. Placeholders if integrating later:
# PLAID_CLIENT_ID=your_client_id_here
# PLAID_SECRET=your_secret_here

# PLAID_ENV=sandbox
# PLAID_PRODUCTS=transactions
# PLAID_COUNTRY_CODES=US